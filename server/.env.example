# Environment Configuration

# Server
NODE_ENV=development
PORT=3000

# Database
# In-memory by default, set to file path for persistence
DATABASE_URL=

# Logging
LOG_LEVEL=info
DEBUG=false

# Security
JWT_SECRET=your-secret-key-change-this
CORS_ORIGIN=*

# Client
CLIENT_PATH=../client/public

# Feature Flags
ENABLE_SYNC_DEBUG=true
ENABLE_CONFLICT_RESOLUTION=true
